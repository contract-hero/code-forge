{
  "description": "Forge v2 protocol enforcement — phase ordering, TDD discipline, parallel reviewer fan-out, post-cycle freeze, and auto-validate on schema artifacts.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/forge-guard.mjs\" pre-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/forge-guard.mjs\" post-tool-use",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
